{
  "expo": {
    "name": "Les Mots Malins",
    "slug": "workspace",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dictee-app",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.1367studio.workspace",
      "infoPlist": {
        "NSCameraUsageDescription": "Pour scanner ta feuille de mots de dictée",
        "NSPhotoLibraryUsageDescription": "Pour choisir une photo de ta feuille de dictée",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {},
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "8d357c48-cccb-4557-8bd4-5f27dff6a794"
      }
    }
  }
}
